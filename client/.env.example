## Transport selection is config-driven only:
## 1. Supabase when both values below are set
## 2. Websocket only when VITE_BACKEND_URL is explicitly set
## 3. Demo by default when neither backend is configured
# VITE_BACKEND_URL=http://localhost:8080
# VITE_SUPABASE_URL=https://<project-ref>.supabase.co
# VITE_SUPABASE_ANON_KEY=<your-anon-key>
